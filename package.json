{
  "name": "remote-browser-keeper",
  "version": "0.1.0",
  "description": "Tray app that supplies passwords/logins to remote browser sessions without exposing them to the AI model.",
  "author": "all-completed",
  "license": "MIT",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.allcompleted.remotebrowserkeeper",
    "productName": "Remote Browser Keeper",
    "files": [
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "portable", "arch": ["x64", "arm64"] }
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "tar.gz", "arch": ["x64", "arm64"] }
      ]
    }
  }
}
