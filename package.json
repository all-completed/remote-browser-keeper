{
  "name": "remote-browser-keeper",
  "version": "0.1.0",
  "description": "Tray app that supplies passwords/logins to remote browser sessions without exposing them to the AI model.",
  "author": "all-completed",
  "license": "MIT",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "build:ui": "vite build",
    "dev:ui": "vite",
    "start": "npm run build:ui && electron .",
    "dist": "npm run build:ui && electron-builder"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.allcompleted.remotebrowserkeeper",
    "productName": "Remote Browser Keeper",
    "files": [
      "src/**/*",
      "renderer-dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
